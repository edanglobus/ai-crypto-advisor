# PostgreSQL connection string used by Prisma.
# Matches the credentials defined in the root docker-compose.yml.
DATABASE_URL="postgresql://crypto:crypto@localhost:5432/crypto_advisor?schema=public"

# Server
PORT=4000
NODE_ENV=development

# CORS origin for the frontend (credentials/cookies enabled)
FRONTEND_URL="http://localhost:5173"

# JWT secrets (use long random strings in real environments)
JWT_ACCESS_SECRET="change-me-access-secret-min-16-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-16-chars"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# External integrations (all optional — the app falls back gracefully if unset).
# CoinGecko: public API needs no key; a free demo key raises rate limits.
COINGECKO_BASE_URL="https://api.coingecko.com/api/v3"
COINGECKO_API_KEY=""
# CryptoPanic: free developer auth token (https://cryptopanic.com/developers/api/)
CRYPTOPANIC_API_KEY=""
# OpenRouter: free-tier key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=""
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
OPENROUTER_MODEL="meta-llama/llama-3.3-70b-instruct:free"
